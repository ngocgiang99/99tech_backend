{
  "name": "resources-api",
  "version": "0.1.0",
  "description": "ExpressJS + TypeScript CRUD service with Postgres and Redis",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "check": "pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:integration",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "db:migrate": "kysely migrate:latest",
    "db:migrate:down": "kysely migrate:rollback",
    "db:reset": "kysely migrate:rollback && kysely migrate:latest",
    "bench:seed": "tsx benchmarks/seed/seed.ts",
    "bench:flush-cache": "tsx benchmarks/seed/flush-cache.ts",
    "bench:smoke": "k6 run benchmarks/scenarios/smoke.js",
    "bench:read": "k6 run benchmarks/scenarios/read-load.js",
    "bench:write": "k6 run benchmarks/scenarios/write-load.js",
    "bench:mixed": "k6 run benchmarks/scenarios/mixed.js",
    "bench:spike": "k6 run benchmarks/scenarios/spike.js",
    "bench:stress": "k6 run benchmarks/scenarios/stress.js",
    "bench:cache:cold": "k6 run benchmarks/scenarios/cache-cold.js",
    "bench:cache:warm": "k6 run benchmarks/scenarios/cache-warm.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "ioredis": "^5.10.1",
    "kysely": "^0.28.16",
    "kysely-ctl": "^0.20.0",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.3",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.4"
  }
}
