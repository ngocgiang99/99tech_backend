# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Database (Postgres)
# Local: postgresql://postgres:postgres@localhost:5432/resources_dev
# Docker Compose: postgresql://postgres:postgres@postgres:5432/resources_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resources_dev

# Database pool
DB_POOL_MAX=10

# Cache (Redis)
REDIS_URL=redis://localhost:6379

# Cache behavior
# Kill switch — set false to bypass the cache entirely (useful for benchmarks).
CACHE_ENABLED=true
# TTL for GET /resources/:id detail cache entries (seconds).
CACHE_DETAIL_TTL_SECONDS=300
# TTL for GET /resources list cache entries (seconds).
CACHE_LIST_TTL_SECONDS=60
# Prefix for the list version counter key used by version-based invalidation.
CACHE_LIST_VERSION_KEY_PREFIX=resource:list:version

# Observability — Prometheus metrics
# Master toggle: when false, the /metrics endpoint is not mounted and the
# HTTP timing middleware is not installed (zero overhead, not "mounted but skipped").
METRICS_ENABLED=true
# Toggle for prom-client's default Node.js runtime metrics (CPU, RSS, heap,
# event loop lag, GC, FDs). Disable for a narrower /metrics output.
METRICS_DEFAULT_METRICS=true
