# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Database (Postgres)
# Local: postgresql://postgres:postgres@localhost:5432/resources_dev
# Docker Compose: postgresql://postgres:postgres@postgres:5432/resources_dev
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resources_dev

# Database pool
DB_POOL_MAX=10

# Cache (Redis)
REDIS_URL=redis://localhost:6379
