# ─── Runtime ────────────────────────────────────────────────────────────
# Node runtime mode (development | test | production)
NODE_ENV=development
# HTTP port the Fastify server binds to
PORT=3000

# ─── Datastores ─────────────────────────────────────────────────────────
# Postgres DSN — used by Kysely (Story 1.4 onwards).
# Host port 55432 is set by problem6/compose.override.yml to avoid colliding
# with sibling projects that publish a Postgres on the default :5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/scoreboard
# Redis DSN — leaderboard ZSET, idempotency SETNX, rate-limit, outbox lock.
# Host port 56379 is set by problem6/compose.override.yml.
REDIS_URL=redis://localhost:56379/0

# ─── NATS JetStream ────────────────────────────────────────────────────
# NATS server URL (comma-separated for clusters; single-node R=1 in local dev).
# Host port 54222 is set by problem6/compose.override.yml.
NATS_URL=nats://localhost:54222
# JetStream stream name — bootstrapped on app start (Story 2.7) and via `mise run nats:init`
NATS_STREAM_NAME=SCOREBOARD
# Stream retention age in seconds — 30 days (MVP value, see ADR-04)
NATS_STREAM_MAX_AGE_SECONDS=2592000
# Max messages retained in the stream
NATS_STREAM_MAX_MSGS=1000000
# Max bytes retained in the stream — 1 GiB
NATS_STREAM_MAX_BYTES=1073741824
# JetStream replica count — 1 in local dev, 3 in production cluster
NATS_STREAM_REPLICAS=1
# `Nats-Msg-Id` dedup window in seconds — 2 minutes (ADR-07 layer 3)
NATS_DEDUP_WINDOW_SECONDS=120

# ─── Auth ───────────────────────────────────────────────────────────────
# HS256 shared secret for verifying internal JWTs (≥32 chars).
# Generate with: openssl rand -hex 32
# WARNING: replace before any non-local use. Keep out of version control.
INTERNAL_JWT_SECRET=<openssl rand -hex 32>
# WARNING: replace before any non-local use — generate a real 32-byte random secret
# (e.g. `openssl rand -hex 32`). Local dev value is intentionally fake.
ACTION_TOKEN_SECRET=change-me-to-a-32-byte-random-secret-in-real-envs
# Previous action-token secret — used during key rotation (GAP-05).
# Set to the old ACTION_TOKEN_SECRET value while rotating, then remove after
# the rollover window closes (see docs/runbooks/action-token-rotation.md).
# Must be ≥32 chars if set. Optional — omit when not rotating.
# ACTION_TOKEN_SECRET_PREV=
# Action token lifetime in seconds (Story 1.10)
ACTION_TOKEN_TTL_SECONDS=300

# ─── Rate Limiting ──────────────────────────────────────────────────────
# Per-user write budget — increments per second (ADR-08)
RATE_LIMIT_PER_SEC=10
# SSE backpressure cap — max concurrent SSE connections per API instance (NFR-01)
MAX_SSE_CONN_PER_INSTANCE=5000
# Top-N users to load into the leaderboard ZSET during cold rebuild (ADR-16)
LEADERBOARD_REBUILD_TOP_N=10000

# ─── Outbox Publisher ───────────────────────────────────────────────────
# How often the outbox worker polls for unpublished rows (milliseconds)
OUTBOX_POLL_INTERVAL_MS=50
# Redis lock TTL for outbox leader election (seconds)
OUTBOX_LOCK_TTL_SECONDS=10
# Time window for coalescing leaderboard.updated events (milliseconds)
OUTBOX_COALESCE_WINDOW_MS=100

# ─── SSE Backpressure ───────────────────────────────────────────────────
# Max pending (un-drained) messages per SSE client before drop-oldest fires (message-count only)
SSE_BACKPRESSURE_MAX_PENDING_MESSAGES=50
# How long (ms) a client can remain buffer-full before being forcibly disconnected
SSE_SLOW_CLIENT_BUFFER_TIMEOUT_MS=5000
# Interval (ms) between SSE heartbeat events sent to keep connections alive
SSE_HEARTBEAT_INTERVAL_MS=15000

# ─── Observability ──────────────────────────────────────────────────────
# Pino log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info
# OTLP traces endpoint — uncomment and set to enable trace export
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
